<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/feed_widget_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/channel_feed_widget_item_background"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/feed_widget_item_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:maxLines="1"
        android:textColor="@color/widget_time"
        android:textSize="11sp" />

    <ImageView
        android:id="@+id/feed_widget_item_image"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="6dp"
        android:adjustViewBounds="true"
        android:background="@drawable/photo_placeholder_in"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <TextView
        android:id="@+id/feed_widget_item_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="8"
        android:textColor="@color/widget_name"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/feed_widget_link_1"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/channel_feed_widget_link_background"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textColor="@color/channel_feed_widget_accent"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/feed_widget_link_2"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/channel_feed_widget_link_background"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textColor="@color/channel_feed_widget_accent"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
