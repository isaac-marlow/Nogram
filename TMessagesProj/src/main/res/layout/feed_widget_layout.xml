<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/TMessages.AppWidget.Background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:theme="@style/Theme.TMessages.AppWidget">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/feed_widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/widget_name"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/feed_widget_page"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="@color/widget_time"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/feed_widget_refresh"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/channel_feed_widget_button_background"
            android:gravity="center"
            android:text="↻"
            android:textColor="@color/channel_feed_widget_accent"
            android:textSize="26sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ListView
            android:id="@+id/list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="6dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:scrollbars="none" />

        <TextView
            android:id="@+id/empty_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/widget_text"
            android:textSize="14sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/feed_widget_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="6dp"
        android:textColor="#D94A4A"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/feed_widget_navigation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/feed_widget_newer"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/channel_feed_widget_button_background"
            android:gravity="center"
            android:text="@string/ChannelFeedWidgetNewer"
            android:textColor="@color/channel_feed_widget_accent"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/feed_widget_older"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/channel_feed_widget_button_background"
            android:gravity="center"
            android:text="@string/ChannelFeedWidgetOlder"
            android:textColor="@color/channel_feed_widget_accent"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
